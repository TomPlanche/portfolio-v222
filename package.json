	"readme": "./README.md",
	"homepage": "https://tomplanche.com",
	"name": "portfolio-v222",
	"description": "Personal portfolio website for Tom Planche, CS engineer student at CNAM Paris.",
	"keywords": ["portfolio", "svelte", "sveltekit", "typescript"],
	"repository": {
		"type": "git",
		"url": "https://github.com/TomPlanche/portfolio-v222"
	},
	"bugs": {
		"url": "https://github.com/TomPlanche/portfolio-v222/issues"
	},
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"serve": "vite build && HOST=0.0.0.0 PORT=3000 node build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25",
		"@types/three": "^0.183.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2"
	},
	"dependencies": {
		"sass": "^1.98.0",
		"three": "^0.183.2"
	}
}
